{
  "id": "nodebb-plugin-wukong-chat-window",
  "name": "WuKong Chat Window",
  "description": "Same-origin standalone chat pages for NodeBB + WuKongIM",
  "staticDirs": {
    "lib": "public/lib"
  },
  "scss": [
    "public/scss/chat-app.scss"
  ],
  "scripts": [
    "public/lib/link-rewriter.js"
  ],
  "templates": "templates",
  "languages": "language",
  "hooks": [
    { "hook": "static:app.load", "method": "init" },
    { "hook": "action:user.create", "method": "onUserCreate" }
  ]
}
