{
  "id": "nodebb-plugin-wukong-chat-window",
  "name": "WuKong Chat Window",
  "description": "Harmony style standalone messages list + chat window for NodeBB + WuKongIM",
  "url": "https://github.com/Hurt6465-ai/nodebb-plugin-wukong-chat-window",
  "library": "./library.js",
  "staticDirs": {
    "lib": "public/lib"
  },
  "templates": "templates",
  "languages": "language",
  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    },
    {
      "hook": "action:user.create",
      "method": "onUserCreate"
    }
  ],
  "nbbpm": {
    "compatibility": "^4.10.0"
  }
}
