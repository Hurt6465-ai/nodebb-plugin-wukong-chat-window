{
  "id": "nodebb-plugin-wukong-chat-window",
  "name": "Wukong Chat Window",
  "description": "Standalone messages list and standalone Wukong chat page for mobile-first NodeBB.",
  "url": "https://github.com/Hurt6465-ai/nodebb-plugin-wukong-chat-window",
  "library": "library.js",
  "staticDirs": {
    "lib": "public/lib"
  },
  "templates": "templates",
  "languages": "language",
  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    },
    {
      "hook": "action:user.create",
      "method": "onUserCreate"
    },
    {
      "hook": "filter:admin.header.build",
      "method": "addAdminNavigation"
    }
  ]
}
